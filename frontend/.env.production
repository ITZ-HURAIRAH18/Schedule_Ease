# Production environment variables
# These are used when building for production (npm run build)

# Backend API: empty = same-origin via Nginx (/api route)
# For Vercel, set: VITE_API_BASE=https://your-backend.vercel.app
VITE_API_BASE=

# Google OAuth Client ID
# Get this from Google Cloud Console > APIs & Services > Credentials
VITE_GOOGLE_CLIENT_ID=77809119535-r5ivv8inbitphbo2rcf5bik2d7grgf5g.apps.googleusercontent.com

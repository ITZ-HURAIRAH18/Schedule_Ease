# Environment variables template
# Copy this file to .env.local for development or .env.production for production
# IMPORTANT: Never commit .env.local or .env.production to version control!

# === Development (.env.local) ===
# Backend API URL for local development
# VITE_API_BASE=http://localhost:5001

# Google OAuth Client ID (get from Google Cloud Console)
# VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# === Production (.env.production) ===
# Backend API URL for Vercel deployment
# VITE_API_BASE=https://schedule-ease-zeta.vercel.app

# Google OAuth Client ID
# VITE_GOOGLE_CLIENT_ID=your-production-google-client-id
